{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "vrchat-data-hub",
    "compatibility_date": "2026-05-18",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "pages_build_output_dir": "dist",
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1
    }
}
